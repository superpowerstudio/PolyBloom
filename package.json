{
  "name": "polybloom",
  "version": "0.1.0",
  "description": "PolyBloom - Ultimate Crypto Bloomberg Terminal + AI Trading Studio",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean --no-cache && rm -rf node_modules"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superpowerstudio/PolyBloom.git"
  },
  "keywords": [
    "crypto",
    "trading",
    "bloomberg",
    "polymarket",
    "terminal"
  ],
  "author": "PolyBloom Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/superpowerstudio/PolyBloom/issues"
  },
  "homepage": "https://github.com/superpowerstudio/PolyBloom#readme",
  "devDependencies": {
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.8",
    "turbo": "^2.8.19"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  },
  "overrides": {
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.8"
  },
  "resolutions": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.8",
    "next": "^16.0.0"
  }
}
